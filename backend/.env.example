# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=nejah_db
DB_SYNC=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# CORS
CORS_ORIGIN=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,https://nejah-online-quran-center.vercel.app
FRONTEND_URL=https://nejah-online-quran-center.vercel.app
BACKEND_URL=https://nejah-online-quran-center.onrender.com

# Zoom Server-to-Server OAuth (platform meetings, registrants, reports, webhooks)
# Zoom Server-to-Server OAuth (Zoom Marketplace app)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=
# Optional: force credential source when both env and database are set (env|database)
# ZOOM_CREDENTIALS_SOURCE=database

ENCRYPTION_KEY=change-this-to-a-32-byte-key-in-production

# PWA Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@nejah-center.com
