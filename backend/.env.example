# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=nejah_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# CORS — comma-separated frontend URLs (Render env: CORS_ORIGINS)
# Local dev is always allowed. *.vercel.app is allowed in production.
CORS_ORIGIN=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,https://nejah-online-quran-center.vercel.app
FRONTEND_URL=https://nejah-online-quran-center.vercel.app

# Zoom Server-to-Server OAuth + Meeting SDK (embedded classroom in /classroom)
# Use the same Client ID and Client Secret from your Zoom OAuth app.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_SECRET_TOKEN=

ENCRYPTION_KEY=change-this-to-a-32-byte-key-in-production
