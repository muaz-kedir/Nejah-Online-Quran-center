# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=nejah_db
DB_SYNC=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# CORS
CORS_ORIGIN=
CORS_ORIGINS=
FRONTEND_URL=

# Zoom Server-to-Server OAuth (platform meetings, registrants, reports, webhooks)
# Zoom Server-to-Server OAuth (Zoom Marketplace app)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=
# Optional: force credential source when both env and database are set (env|database)
# ZOOM_CREDENTIALS_SOURCE=database

ENCRYPTION_KEY=change-this-to-a-32-byte-key-in-production

# PWA Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Must be mailto:your@email.com or https://your-site.com (bare emails are auto-prefixed with mailto:)
VAPID_EMAIL=mailto:admin@nejah-center.com
VAPID_SUBJECT=mailto:admin@nejah-center.com

# Firebase Cloud Messaging (FCM)
# Base64-encoded Firebase Admin SDK service account JSON
# Generate from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Then encode: base64 -w0 path/to/serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_BASE64=
# Alternative: individual fields (less secure for multi-line private keys)
# FIREBASE_PROJECT_ID=
