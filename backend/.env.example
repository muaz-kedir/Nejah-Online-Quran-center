# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=nejah_db
# Set to true on Render so TypeORM creates/updates tables on deploy
# Optional when DATABASE_URL is set — schema sync is automatic on hosted Postgres
DB_SYNC=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# CORS — comma-separated frontend URLs (Render env: CORS_ORIGINS)
# Local dev is always allowed. *.vercel.app is allowed in production.
CORS_ORIGIN=http://localhost:8080
<<<<<<< Updated upstream
