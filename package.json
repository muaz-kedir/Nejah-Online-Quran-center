{
  "name": "nejah-online-quran-center",
  "version": "1.0.0",
  "private": true,
  "description": "Online Quran and Islamic education platform",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:backend": "npm run start:dev --prefix backend",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev\"",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "format": "npm run format --prefix frontend",
    "install:frontend": "npm install --prefix frontend",
    "deploy:vercel": "vercel",
    "deploy:vercel:prod": "vercel --prod"
  },
  "keywords": [
    "quran",
    "islamic-education",
    "online-learning",
    "react",
    "tailwindcss"
  ],
  "author": "Nejah Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
